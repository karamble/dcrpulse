# Decred Dashboard Environment Configuration
# Copy this file to .env and fill in your values

# Volume Configuration
# For app store integration (Umbrel, Start9, CasaOS), this can be overridden
# Standalone: uses Docker named volume (default: dcrpulse_app-data)
# Umbrel: set to managed path like /umbrel/app-data/<app-id>
# Leave empty or set to "app-data" for default behavior
#APP_DATA_DIR=app-data

# Decred RPC Credentials
# These are used by both dcrd and the backend
DCRD_RPC_USER=decred
DCRD_RPC_PASS=change_this_to_a_secure_password

# Dcrwallet RPC Credentials
# Used by dcrwallet and the backend to access wallet
DCRWALLET_RPC_USER=dcrwallet
DCRWALLET_RPC_PASS=change_this_to_a_secure_wallet_password

# Docker Image Tags (optional)
# Set these to use pre-built images instead of building locally
# Significantly speeds up deployment and ensures consistent builds
# Images are published to GitHub Container Registry (GHCR)
# Leave commented to build from source (default behavior)
#DCRD_IMAGE_TAG=latest
#DCRWALLET_IMAGE_TAG=latest
#DASHBOARD_IMAGE_TAG=latest

# Build Configuration
# Only used if building from source (no image tags set above)
# Optional: dcrd version/branch to build (default: release-v2.1.5)
# Can be a tag (e.g., release-v2.1.5) or branch name
#DCRD_VERSION=release-v2.1.5

# Optional: dcrwallet version/branch to build (default: release-v2.1.5)
# Can be a tag (e.g., release-v2.1.5) or branch name
#DCRWALLET_VERSION=release-v2.1.5

# dcrd Extra Arguments
# Enable transaction index for block explorer functionality
# This allows full transaction lookup by hash
# Note: First startup with this flag will trigger a full blockchain reindex (may take hours)
DCRD_EXTRA_ARGS=--txindex

# Host interface for dcrd's P2P port (standalone only; the Umbrel build does not
# expose it). Default 0.0.0.0 accepts inbound on your public IP. Set to 127.0.0.1
# to refuse clearnet inbound and accept inbound only via the Tor onion service.
#DCRD_P2P_HOST_BIND=0.0.0.0

# Host interface and port the dashboard UI is published on. Default is loopback
# only (127.0.0.1): the UI is reachable from the machine running the stack, not
# the LAN. To reach the dashboard from another device set DASHBOARD_HOST_BIND to
# 0.0.0.0 (or, preferred, keep it loopback and front the UI with a TLS reverse
# proxy - the dashboard speaks plain HTTP). The Umbrel/CasaOS builds reach the UI
# through their app proxy and ignore this. Change DASHBOARD_PORT if 8080 is taken.
#DASHBOARD_HOST_BIND=127.0.0.1
#DASHBOARD_PORT=8080

# Host interface and port the Bison Relay MCP bridge (brclientd) is published
# on (default loopback only). It lets AI agents call MCP tool services offered
# by Bison Relay bots, paying per call with Lightning tips. Set MCP_BRIDGE_HOST
# to 0.0.0.0 to reach it from another device; it is plain HTTP behind a bearer
# token, so prefer an SSH tunnel or reverse proxy. This is only the host
# publish - the listener inside the container stays 0.0.0.0:8891 (a fixed
# detail of how Docker reaches it, set via --mcp.mcplisten in the supervisor,
# which overrides any brclientd.conf value).
#MCP_BRIDGE_HOST=127.0.0.1
#MCP_BRIDGE_PORT=8891

# Dcrwallet Address Gap Limit (default: 400)
# This controls how many consecutive unused addresses the wallet will monitor
# Increase this if you have funds at higher address indices that aren't being discovered
# Common values: 100 (fast), 400 (recommended), 1000 (thorough), 5000 (very thorough)
# Higher values increase memory usage and rescan time
DCRWALLET_GAP_LIMIT=100

# Optional: Uncomment for testnet
# DCRD_TESTNET=1

# Bison Relay Daemon (brclientd) Data Directory
# Path where brclientd's appdata (clientdb, embeds, downloads, mTLS certs,
# logs) lives. The dashboard reads embed/download files and the brclientd
# log from this path.
# Standalone: defaults to ~/.brclientd (matches what brclientd writes
# to when run as a binary on the host with no --appdata flag).
# Docker/Umbrel: docker-compose.yml sets this to /app-data/brclientd to
# match the brclientd container's volume mount. Override here only if
# you ran brclientd with a non-default --appdata.
#BRCLIENTD_DATA_DIR=~/.brclientd